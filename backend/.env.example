# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=KrishiMitra-Backend
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=krishimitra

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─── Google Earth Engine ──────────────────────────────────────────────────────
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/gee-service-key.json
# In production, provide the JSON content via this variable instead of a file
GEE_JSON_CONTENT=

# ─── Data Gov (Market API) ────────────────────────────────────────────────────
DATA_GOV_API_KEY=

# ─── AI Provider Overrides (Optional) ─────────────────────────────────────────
AI_PROVIDER=gemini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Cache TTL (seconds) ──────────────────────────────────────────────────────
WEATHER_CACHE_TTL=1800
GEOCODE_CACHE_TTL=86400

# ─── Voice ────────────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
PIPER_MODEL_PATH=./models/piper
AUDIO_OUTPUT_DIR=./audio_outputs

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
